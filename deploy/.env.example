# Copy this file to .env in the same directory (~/apps/deploy/.env) and fill in real values.
# docker compose reads .env automatically from the directory it is run in.

# --- Portfolio admin panel (web service) ---
ADMIN_PASSWORD=changeme
# Password required by scripts/serve.py POST /api/content to accept admin edits.

# --- nhg-rag-demo (rag, rag-ingest services) ---
GROQ_API_KEY=
# Free API key from https://console.groq.com, used for the Groq LLM path (LLM_PROVIDER=groq).

# --- thl-etl (etl-db, etl-pipeline, metabase services) ---
POSTGRES_USER=pipeline
# Postgres role used by both the ETL pipeline and Metabase's own metabase database.
POSTGRES_PASSWORD=changeme
# Password for POSTGRES_USER. Change this from the default before exposing anything publicly.
POSTGRES_DB=thldb
# Database name the ETL pipeline writes its raw/analytics schemas into.

# --- Cloudflare Tunnel (cloudflared service) ---
TUNNEL_TOKEN=
# Token for the tunnel created in Cloudflare Zero Trust, see DEPLOY.md step 3.

# --- Contact-note email (web service, optional) ---
SMTP_HOST=
# SMTP server for contact-note emails, e.g. smtp.gmail.com. Leave blank to only store notes.
SMTP_PORT=587
# SMTP STARTTLS port, usually 587.
SMTP_USER=
# SMTP username / from address, e.g. you@gmail.com.
SMTP_PASS=
# SMTP password. For Gmail use an App Password, not the account login password.
CONTACT_TO=pyry.kiviluoma@aalto.fi
# Where contact notes are emailed.
